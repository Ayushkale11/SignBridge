# ============================================
# SignBridge - Git Ignore Rules
# ============================================

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
env/
.venv/

# IDE settings
.vscode/
.idea/
*.swp
*.swo

# OS files
Thumbs.db
.DS_Store

# Trained models (large files - retrain locally)
models/*.pkl

# Dataset (collected locally - too large for GitHub)
dataset/*.csv

# Distribution
*.egg-info/
dist/
build/
